generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        Int        @id @default(autoincrement())
  name      String
  price     Int
  photoUrl  String
  category  Category
  sizes     String[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  favorites Favorite[]
}

enum Category {
  PANTS
  BAGS
  JACKETS
  HOODIES
  TEES
}

model Favorite {
  id         Int      @id @default(autoincrement())
  telegramId String
  productId  Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([telegramId, productId])
}

model AdminSession {
  id         Int      @id @default(autoincrement())
  telegramId String   @unique
  step       String?
  data       Json     @default("{}")
  updatedAt  DateTime @updatedAt
}
